<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allows plain HTTP only to the emulator's host-loopback alias, used to reach the
         FastAPI backend running on the dev machine during local development. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>